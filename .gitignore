# INDOMINUS OS
# Root-level .gitignore

# ─────────────────────────────────────────────────────────────────────────────
# Rust / Cargo
# ─────────────────────────────────────────────────────────────────────────────
/target/
Cargo.lock          # Committed for applications, ignored for library-only crates.
                    # We COMMIT Cargo.lock because this is a binary project.
                    # Delete this line if you want to commit it (recommended).

# ─────────────────────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────────────────────
/build/
*.img
*.iso
*.efi

# ─────────────────────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ─────────────────────────────────────────────────────────────────────────────
# Debug artifacts
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.dump
