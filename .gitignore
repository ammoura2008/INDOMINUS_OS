# INDOMINUS OS
# Root-level .gitignore

# ─────────────────────────────────────────────────────────────────────────────
# Rust / Cargo
# ─────────────────────────────────────────────────────────────────────────────
/target/

# ─────────────────────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────────────────────
/build/
*.img
*.iso
*.efi

# ─────────────────────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ─────────────────────────────────────────────────────────────────────────────
# Debug artifacts
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.dump
out_*.txt
test_b*.txt
qemu_output.txt

# ─────────────────────────────────────────────────────────────────────────────
# Generated / temporary
# ─────────────────────────────────────────────────────────────────────────────
tmp/
venv/
*.jpg
